# newscraft environment variables
# Copy to .env and fill in your values

# 公众号 API (发布阶段必需)
MP_APP_ID=your_mp_app_id
MP_APP_SECRET=your_mp_app_secret

# 百度 AI Studio API Key (写稿 + 配图必需)
# 申请地址: https://aistudio.baidu.com/
AI_STUDIO_API_KEY=your_ai_studio_api_key

# 代理 (可选, 国内访问 Reddit/HN 等境外源需要)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 通知 Webhook (可选, 审稿提醒)
# NOTIFY_WEBHOOK_URL=https://your-webhook-url

# 流水线超时 (分钟, 可选)
# TOPIC_SELECTION_TIMEOUT=30
# REVIEW_APPROVAL_TIMEOUT=30

# Docker 数据目录 (可选, 默认 /data)
# DATA_DIR=/data
